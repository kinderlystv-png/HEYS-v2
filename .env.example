# ===========================================
# HEYS v2 - Environment Variables Template
# ===========================================
# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ===========================================
# 🔐 Supabase Configuration (REQUIRED)
# ===========================================
# Получите credentials на https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend → Supabase (service role, server-to-server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram → Supabase curator mapping (TELEGRAM_ID=SUPABASE_USER_UUID)
# Пример: TELEGRAM_CURATOR_MAP=123456789=00000000-0000-4000-8000-aaaaaaaaaaaa,987654321=00000000-0000-4000-8000-bbbbbbbbbbbb
TELEGRAM_CURATOR_MAP=

# ===========================================
# 🌐 Server Configuration
# ===========================================

# Frontend port (Vite dev server)
PORT=3001
VITE_PORT=3001

# API server port
API_PORT=4001

# Base URL для API из приложений Vite (например tg-mini)
VITE_API_URL=http://localhost:4001

# Список разрешённых Origin для CORS (через запятую)
# Пример: API_ALLOWED_ORIGINS=https://curator.heysapp.com,https://mini.heys.app
# Если переменная не задана, доступны только dev-origin'ы (localhost:3000-3003)
API_ALLOWED_ORIGINS=

# Node environment
NODE_ENV=development

# ===========================================
# 📊 Analytics & Monitoring (OPTIONAL)
# ===========================================

# Sentry DSN для error tracking
# Получите на https://sentry.io/settings/projects/
VITE_SENTRY_DSN=

# Sentry environment tag
VITE_SENTRY_ENVIRONMENT=development

# ===========================================
# 🪵 Logging Configuration (OPTIONAL)
# ===========================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ===========================================
# 🔧 Development Settings (OPTIONAL)
# ===========================================

# Enable React DevTools
VITE_REACT_DEVTOOLS=true

# Enable source maps in production
VITE_SOURCE_MAPS=false

# Enable verbose logging
VITE_DEBUG=false

# ===========================================
# 🧪 Local Test Credentials (LOCAL ONLY)
# ===========================================
# Для ручного тестирования HEYS во встроенном браузере.
# Заполняйте только в локальном .env.local — не коммитьте реальные значения.

HEYS_TEST_PHONE=
HEYS_TEST_PIN=
HEYS_TEST_CURATOR_EMAIL=
HEYS_TEST_CURATOR_PASSWORD=

# ===========================================
# 🤖 Telegram Bot Configuration (для mini-app)
# ===========================================
# Получите токен у @BotFather в Telegram
# ВАЖНО: Реальный токен храните только в .env.local (не коммитится в git)

TELEGRAM_BOT_TOKEN=your_bot_token_here

# Разрешённые Telegram user IDs (через запятую)
# Получите свой ID через @userinfobot в Telegram
# Оставьте пустым чтобы разрешить всех (только для dev!)
# Пример: TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# ===========================================
# 🔧 Ngrok для локального тестирования mini-app
# ===========================================
# 1. Запустите mini-app: pnpm run dev:tg-mini (порт 3002)
# 2. Запустите ngrok: ngrok http 3002
# 3. Скопируйте URL (например: https://abc123.ngrok-free.dev)
# 4. Добавьте домен в apps/tg-mini/vite.config.ts → server.allowedHosts
# 5. Настройте Menu Button в @BotFather с этим ngrok URL

# ===========================================
# 🚀 Production Settings
# ===========================================
# Для production установите:
# NODE_ENV=production
# VITE_SOURCE_MAPS=false
# VITE_DEBUG=false
# LOG_LEVEL=warn
# VITE_SENTRY_ENVIRONMENT=production
