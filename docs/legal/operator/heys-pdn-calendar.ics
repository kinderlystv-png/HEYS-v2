BEGIN:VEVENT
UID:heys-pdn-monthly-audit@heyslab
DTSTAMP:20260615T090000Z
DTSTART;TZID=Europe/Moscow:20260701T100000
DTEND;TZID=Europe/Moscow:20260701T110000
RRULE:FREQ=MONTHLY;BYDAY=MO,TU,WE,TH,FR;BYSETPOS=1
SUMMARY:HEYS PDN monthly audit
DESCRIPTION:Run pnpm pdn:monthly-audit. Fill heys-pdn-monthly-audit outside repo if real PDN/RKN evidence exists. Check code DB landing docs RKN integrations gaps.
BEGIN:VALARM
TRIGGER:-PT30M
ACTION:DISPLAY
DESCRIPTION:HEYS PDN monthly audit
END:VALARM
END:VEVENT
BEGIN:VEVENT
UID:heys-rkn-change-check@heyslab
DTSTAMP:20260615T090000Z
