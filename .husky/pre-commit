#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

pnpm exec lint-staged
AGENT_STAGING_MODE=$(node scripts/check-agent-staging.mjs --print-mode) || exit 1
node scripts/check-agent-staging.mjs --mode="$AGENT_STAGING_MODE" || exit 1
if [ "$AGENT_STAGING_MODE" = "agent" ]; then
  node scripts/auto-sync-legacy-bundles.mjs --mode=agent-check
else
  node scripts/auto-sync-legacy-bundles.mjs --mode=integration
fi
node scripts/lint-lazy-chunk-constant-access.mjs
node scripts/check-pricing-sync.cjs
node scripts/lint-sync-merge-cjs-mirror.mjs --staged

# 2026-05-28: auto-bump localStorage allowlist при line drift (от параллельных
# правок). Если в файле число hits == число allowlist-entries, но строки не
# совпадают — это безопасный drift, переписываем номера и стейджим. Если
# count различается (новый/удалённый setItem) — script ничего не трогает,
# pre-push отчитается как раньше.
if git diff --quiet -- scripts/bootstrap-bypass-allowlist.txt 2>/dev/null && \
   git diff --cached --quiet -- scripts/bootstrap-bypass-allowlist.txt 2>/dev/null; then
  node scripts/lint-direct-localstorage-writes.mjs --auto-fix > /dev/null 2>&1 || true
  if ! git diff --quiet -- scripts/bootstrap-bypass-allowlist.txt 2>/dev/null; then
    echo "[pre-commit] 🔧 Allowlist line drift auto-fixed — staging update."
    git add scripts/bootstrap-bypass-allowlist.txt
  fi
else
  echo "[pre-commit] ⚠ bootstrap allowlist already dirty — leaving it untouched."
fi

if git diff --quiet -- scripts/raw-session-clear-allowlist.txt 2>/dev/null && \
   git diff --cached --quiet -- scripts/raw-session-clear-allowlist.txt 2>/dev/null; then
  node scripts/lint-raw-session-clear.mjs --auto-fix > /dev/null 2>&1 || true
  if ! git diff --quiet -- scripts/raw-session-clear-allowlist.txt 2>/dev/null; then
    echo "[pre-commit] 🔧 raw-session-clear allowlist line drift auto-fixed — staging update."
    git add scripts/raw-session-clear-allowlist.txt
  fi
else
  echo "[pre-commit] ⚠ raw-session allowlist already dirty — leaving it untouched."
fi
