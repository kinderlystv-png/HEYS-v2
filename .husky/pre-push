#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Canonical local gate: fast source-scope, secret/static guards and relevant
# tests only. Clean legacy rebuild + full apps/web Vitest remain fail-closed in
# Deploy to Yandex Cloud for the same pushed source SHA.
current_head=$(git rev-parse HEAD 2>/dev/null || true)
if [ -n "$HEYS_PUSH_AGENT_PRECHECKED_HEAD" ] && [ "$HEYS_PUSH_AGENT_PRECHECKED_HEAD" = "$current_head" ]; then
  echo "✅ Fast push gates already passed in push:agent for HEAD ${current_head}."
  exit 0
fi

remote_name=${1:-origin}
branch_name=$(git branch --show-current 2>/dev/null || true)
if [ -z "$branch_name" ]; then
  echo "❌ Cannot determine current branch. Push cancelled."
  echo "Next command: git branch --show-current"
  exit 1
fi

base_ref="${remote_name}/${branch_name}"
echo "🔍 Fast pre-push gates for ${base_ref}..HEAD..."
node scripts/push-preflight.mjs --base="$base_ref" --ref=HEAD || exit 1

echo "✅ Fast local gates passed; CI owns clean bundles and the full suite."
