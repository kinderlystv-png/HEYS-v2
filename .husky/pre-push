#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "📝 Проверка What's New для текущего deploy/push..."

check_status=0
pnpm prepare-release:check || check_status=$?

if [ -t 1 ]; then
  echo ""
  node scripts/prepare-release.mjs --preview || true

  if [ "$check_status" -ne 0 ]; then
    echo ""
    echo "⚠️ What's New не готов: нужно подтвердить тексты нововведений и/или скриншоты."
    echo "💡 Рекомендуемый сценарий перед push: pnpm push:ready"
    echo "   Эта команда сразу показывает тексты, спрашивает про скрины, валидирует What's New и при необходимости делает follow-up commit."
    printf "Запустить pnpm push:ready сейчас? [Y/n] "
    read answer
    case "$answer" in
      n|N)
        echo "❌ Push отменён. Сначала запусти pnpm push:ready."
        exit 1
        ;;
      *)
        pnpm push:ready -- --skip-preview || exit 1
        pnpm prepare-release:check || {
          echo "❌ What's New всё ещё не готов. Push отменён."
          exit 1
        }
        ;;
    esac
  else
    echo ""
    echo "✅ What's New уже готов."
    echo "💬 Перед push можно:"
    echo "   • просто продолжить пуш;"
    echo "   • открыть pnpm push:ready и подправить формулировки/скрины;"
    echo "   • отменить push."
    printf "Продолжить push / открыть push:ready / отменить? [Y/e/n] "
    read answer
    case "$answer" in
      e|E|у|У)
        pnpm push:ready -- --skip-preview || exit 1
        pnpm prepare-release:check || {
          echo "❌ What's New после редактирования не прошёл проверку. Push отменён."
          exit 1
        }
        ;;
      n|N|т|Т)
        echo "❌ Push отменён пользователем."
        exit 1
        ;;
      *)
        echo "✅ Продолжаем push с текущим What's New."
        ;;
    esac
  fi
else
  if [ "$check_status" -ne 0 ]; then
    echo "❌ Push отменён. Запусти: pnpm push:ready"
    exit 1
  fi
fi

echo "🔍 Проверка прямых localStorage.setItem (Phase 3 lint gate, warn-only)..."
node scripts/lint-direct-localstorage-writes.mjs || {
  echo "❌ localStorage lint завершился с ошибкой (новые нелистованные вызовы). Push отменён."
  exit 1
}

echo "📦 Проверка bundle size budget (P0-D, +5% guard)..."
node scripts/lint-bundle-size.mjs || {
  echo "❌ Bundle size guard: critical-path бандл вырос >+5% от baseline. Push отменён."
  echo "💡 Если рост оправдан — добавь [bundle-size-ok] в commit message."
  exit 1
}

echo "🧪 Запуск полного test suite..."

# До 2026-05-21 здесь был whitelist из 14 «критических» файлов. За время его
# существования в extended suite незаметно накопилось 32 падающих теста
# (см. коммиты 4bda3d76, 39bf818e — расследование и фикс). Прогон полного
# suite дороже всего на ~3 сек (4s → 7s), но ловит регрессии вроде
# stale-моков и path-багов на pre-push, а не через жалобы клиентов.
(cd apps/web && node_modules/.bin/vitest run)

if [ $? -ne 0 ]; then
  echo "❌ Тесты не прошли! Push отменён."
  exit 1
fi

echo "✅ Все тесты прошли!"
