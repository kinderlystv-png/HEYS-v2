# Yandex Cloud Functions - Secrets Template
# COPY THIS FILE TO .env AND FILL WITH ACTUAL VALUES
# NEVER COMMIT .env TO GIT!

# PostgreSQL (heys_production database)
PG_HOST=rc1b-obkgs83tnrd6a2m3.mdb.yandexcloud.net
PG_PORT=6432
PG_DATABASE=heys_production
PG_USER=heys_admin
PG_PASSWORD=your_actual_password_here

# PostgreSQL SSL mode
PG_SSL=verify-full

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Session & Auth (CRITICAL for RPC/Auth functions)
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# YuKassa (для heys-api-payments)
YUKASSA_SHOP_ID=your_yukassa_shop_id
YUKASSA_SECRET_KEY=your_yukassa_secret_key
# HMAC-секрет для проверки подписи webhook'ов (опционально; настраивается
# в личном кабинете ЮKassa → Магазины → Уведомления → HMAC). Без него
# webhook валидируется только по IP-allowlist.
YUKASSA_WEBHOOK_SECRET=

# Internal cron token (для poll-фолбэка pending-платежей в scripts/cron-payments-poll.js).
# Генерируется один раз и хранится в Yandex Lockbox; cron передаёт его в
# заголовке X-Internal-Cron-Token, что разрешает вызывать /payments/webhook
# в обход IP-allowlist ЮKassa.
INTERNAL_CRON_TOKEN=

# Telegram-бот для клиентов (P0.7 — heys-bot-client).
# Отдельный бот (НЕ TELEGRAM_BOT_TOKEN, который для алертов кураторам).
# Создаётся через @BotFather. Сетим webhook на https://api.heyslab.ru/bot/webhook
TELEGRAM_CLIENT_BOT_TOKEN=
APP_URL=https://app.heyslab.ru

# Yandex Cloud
YC_FOLDER_ID=b1gnv1a4q8i6de6atl6n

# Web Push (VAPID) — для heys-api-push (subscribe/send) и heys-cron-reminders.
# Сгенерировать: `npx web-push generate-vapid-keys --json`.
# Public key прокидывается на фронт через GET /push/vapid-key.
# Private key только в backend, никогда не уходит к клиенту.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@heyslab.ru
