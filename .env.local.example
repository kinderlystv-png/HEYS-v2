# E2E test credentials for курaтор-pollution suite (TESTS/e2e/curator-switch-pollution.spec.ts)
# и perf-budget (TESTS/e2e/perf-budget.spec.ts).
# COPY к .env.local (gitignored), заполни своими значениями. НЕ коммить .env.local.
#
# Test isolation: тесты используют DEDICATED test clients созданных
# scripts/db/migrations/2026-05-31_create_e2e_test_clients.sql. Real
# user data (Александра/Poplanton) НЕ trouched. См. TESTS/e2e/README.md.

# === E2E dedicated test clients (Phase 0 migration creates them) ===
# UUID'ы deterministic, фиксированы migration'ом.
HEYS_TEST_E2E_CLIENT_ALEX_ID=11111111-1111-1111-1111-111111111111
HEYS_TEST_E2E_CLIENT_POPL_ID=22222222-2222-2222-2222-222222222222
# Имена как они отображаются в dropdown'е курaтора (для UI selector в курaторском switch test).
HEYS_TEST_E2E_CLIENT_ALEX_NAME=E2E-TestAlex
HEYS_TEST_E2E_CLIENT_POPL_NAME=E2E-TestPopl
# PIN credentials. Префикс E2E_ALEX / E2E_POPL — формат под getNamedPinCredentials():
# `HEYS_TEST_PHONE_${prefix}` + `HEYS_TEST_PIN_${prefix}`.
HEYS_TEST_PHONE_E2E_ALEX=70000000001
HEYS_TEST_PIN_E2E_ALEX=0000
HEYS_TEST_PHONE_E2E_POPL=70000000002
HEYS_TEST_PIN_E2E_POPL=1111

# === Курaтор для test 3 (используется тот же что и для реальных клиентов — re-uses) ===
HEYS_TEST_CURATOR_EMAIL=
HEYS_TEST_CURATOR_PASSWORD=

# === DEPRECATED — real user credentials (оставлены для backward compat,
# новые тесты используют E2E_* выше; НЕ заполняй если не нужно legacy specs) ===
# HEYS_TEST_PHONE_ALEX=
# HEYS_TEST_PIN_ALEX=
# HEYS_TEST_PHONE_POPL=
# HEYS_TEST_PIN_POPL=
# HEYS_TEST_CURATOR_CLIENT_ALEX_NAME=Александра
# HEYS_TEST_CURATOR_CLIENT_POPL_NAME=Poplanton

# Optional: dev server URL (default http://localhost:3001)
# HEYS_E2E_BASE_URL=http://localhost:3001
