# E2E test credentials for курaтор-pollution suite (TESTS/e2e/curator-switch-pollution.spec.ts).
# COPY к .env.local (gitignored), заполни своими значениями. НЕ коммить .env.local.

# === PIN auth (test 1, test 2) ===
HEYS_TEST_PHONE_ALEX=
HEYS_TEST_PIN_ALEX=

HEYS_TEST_PHONE_POPL=
HEYS_TEST_PIN_POPL=

# === Курaтор + switch (test 3) ===
HEYS_TEST_CURATOR_EMAIL=
HEYS_TEST_CURATOR_PASSWORD=

# Имена клиентов как они отображаются в dropdown'е курaтора (нужны для click selector)
HEYS_TEST_CURATOR_CLIENT_ALEX_NAME=Александра
HEYS_TEST_CURATOR_CLIENT_POPL_NAME=Poplanton

# Optional: dev server URL (default http://localhost:3001)
# HEYS_E2E_BASE_URL=http://localhost:3001
