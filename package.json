{
  "name": "@heys/monorepo",
  "version": "13.0.0",
  "private": true,
  "description": "HEYS - Monorepo for nutrition and training management system",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*",
    "scripts/eslint-rules"
  ],
  "scripts": {
    "DISABLED_dev:tg-mini": "pnpm --filter='@heys/tg-mini' run dev",
    "DISABLED_mobile": "pnpm --filter mobile run start",
    "DISABLED_mobile:clear": "pnpm --filter mobile run start:clear",
    "agent:worktree": "node scripts/agent-worktree.mjs",
    "agents:integrate": "node scripts/integrate-agents.mjs",
    "arch:check": "bash scripts/check-module-architecture.sh",
    "arch:limits:generate": "node scripts/generate-module-limits.js",
    "arch:metrics": "node scripts/arch-metrics.js --all",
    "bot:crm-test": "node --test yandex-cloud-functions/heys-bot-client/__tests__/start-lead-crm.test.cjs",
    "build": "turbo run build",
    "build:analyze": "tsx scripts/analyze-bundle.ts",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:packages": "pnpm -r --filter=packages/* run build",
    "bump:legal": "bash scripts/bump-legal-version.sh",
    "bundle:legacy": "node scripts/bundle-legacy.mjs",
    "bundle:legacy:auto": "node scripts/auto-sync-legacy-bundles.mjs",
    "bundle:legacy:dry": "node scripts/bundle-legacy.mjs --dry-run",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "clean": "turbo run clean && rimraf dist node_modules/.cache",
    "css:audit": "bash scripts/css-audit.sh",
    "deps:check": "pnpm audit",
    "deps:update": "pnpm update -r",
    "dev": "cross-env PORT=3001 turbo run dev --concurrency=15",
    "dev:api": "node -r dotenv/config packages/core/src/server.js dotenv_config_path=.env.development.local",
    "dev:landing": "cross-env PORT=3003 pnpm --filter='@heys/landing' run dev",
    "dev:local": "concurrently -k -n \"api,web\" --prefix-colors \"cyan,green\" \"cross-env PORT=4001 API_PORT=4001 DATABASE_NAME=projectB NODE_ENV=development node packages/core/src/server.js\" \"cross-env PORT=3001 pnpm --filter='@heys/web' run dev\"",
    "dev:web": "cross-env PORT=3001 pnpm --filter='@heys/web' run dev",
    "dev:web:full": "concurrently -k -n web,iw \"pnpm --filter='@heys/web' run dev\" \"pnpm --filter='@heys/web' run dev:iw-config\"",
    "docker:build": "docker build -t heys:latest .",
    "docker:build:dev": "docker build --target development -t heys:dev .",
    "docker:compose:dev": "docker-compose up heys-dev",
    "docker:compose:down": "docker-compose down",
    "docker:compose:up": "docker-compose up",
    "docker:run": "docker run -p 3001:3001 heys:latest",
    "docker:run:dev": "docker run -p 3001:3001 -v $(pwd):/app heys:dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "healthcheck": "node scripts/healthcheck.js",
    "iw:sync-config": "node scripts/sync-iw-inline-config.cjs",
    "legacy:serve": "npx http-server dist/production -p 3001 -c-1",
    "legacy:start": "python -m http.server 8001",
    "legacy:test": "jest",
    "lint": "turbo run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "lint:log": "bash scripts/lint-log.sh",
    "lint:shared-cache": "node scripts/lint-shared-cache-writes.mjs",
    "monitoring:check": "node scripts/monitoring.js check",
    "monitoring:metrics": "node scripts/monitoring.js metrics",
    "monitoring:start": "node scripts/monitoring.js start",
    "optimize:images": "tsx scripts/optimize-images.ts",
    "payments:gateway": "node scripts/prepare-payments-gateway.mjs",
    "payments:webhook-test": "node --test yandex-cloud-functions/heys-api-payments/__tests__/payment-status-webhook.test.cjs",
    "pdn:monthly-audit": "node scripts/lint-pdn-monthly-audit.mjs",
    "perf:analyze": "tsx scripts/analyze-bundle.ts",
    "perf:baseline": "node scripts/performance-baseline-simple.js",
    "perf:report": "npm run perf:analyze && npm run perf:baseline",
    "prepare": "husky install",
    "prepare-release": "node scripts/prepare-release.mjs",
    "prepare-release:check": "node scripts/prepare-release.mjs --check",
    "privacy:marketing": "node scripts/lint-marketing-privacy-metadata.mjs",
    "push:agent": "node scripts/push-agent.mjs",
    "push:ready": "node scripts/release-prepare-and-commit.mjs",
    "push:safe": "node scripts/push-safe.mjs",
    "release": "pnpm run build:packages && changeset publish",
    "release:prepare-and-commit": "node scripts/release-prepare-and-commit.mjs",
    "security:l6-watchdogs": "node scripts/security/l6-watchdogs-check.mjs",
    "security:sbom": "node scripts/security/generate-sbom.js",
    "security:strict-readiness": "node scripts/security/strict-readiness-check.mjs",
    "ship": "node scripts/ship.mjs",
    "test": "turbo run test",
    "test:all": "node -e \"require('fs').mkdirSync('coverage/.tmp',{ recursive: true })\" && cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --coverage",
    "test:coverage": "pnpm -r run test:coverage",
    "test:db": "vitest run TESTS/db TESTS/regressions/468a2947-audit-tz-fix.test.ts --no-coverage --test-timeout=60000 --hook-timeout=60000 --pool=threads",
    "test:e2e": "playwright test",
    "test:e2e:curator-switch": "playwright test -c playwright.curator-switch.config.ts",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:perf-budget": "playwright test -c playwright.perf-budget.config.ts",
    "test:e2e:pin": "playwright test -c playwright.heys-pin.config.ts",
    "test:e2e:planning-perf": "playwright test -c playwright.planning-perf.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:packages": "pnpm -r --filter='./packages/*' run test",
    "test:regressions": "vitest run TESTS/regressions --exclude='**/*-db.test.ts' --exclude='**/468a*.test.ts' --no-coverage",
    "test:rpc": "vitest run TESTS/rpc --no-coverage",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run",
    "test:watch": "pnpm -r run test:watch",
    "test:web:critical": "vitest run apps/web/__tests__/yandex-api-session-guards.test.js apps/web/__tests__/heys-auth-login-client.test.js apps/web/__tests__/heys-auth-session.test.js apps/web/__tests__/heys-auth-create-reset-pin.test.js apps/web/__tests__/pending-queue-pure.test.js",
    "test:web:sync-critical": "vitest run apps/web/__tests__/yandex-api-session-guards.test.js apps/web/__tests__/heys-auth-login-client.test.js apps/web/__tests__/heys-auth-session.test.js apps/web/__tests__/pending-queue-pure.test.js apps/web/__tests__/sync-queue-runtime-pure.test.js apps/web/__tests__/pwa-update-logic.test.js",
    "type-check": "turbo run type-check",
    "validate:ci": "ruby -ryaml -e \"Dir['.github/workflows/*.{yml,yaml}'].each { |f| YAML.load_file(f) }; puts 'CI YAML OK'\"",
    "verify:legacy-bundles": "node scripts/verify-legacy-bundles.mjs",
    "workspace:graph": "pnpm list --depth=0 --json"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-error-on-unmatched-pattern"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "dependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dompurify": "^3.2.7",
    "express": "^4.21.4",
    "fuse.js": "^7.0.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "svelte": "^5.51.5",
    "tinyglobby": "^0.2.15",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@heys/eslint-plugin": "workspace:*",
    "@playwright/test": "^1.56.1",
    "@sentry/browser": "^10.8.0",
    "@swc/core": "^1.13.5",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "autoprefixer": "^10.4.21",
    "chalk": "^5.6.0",
    "chrome-launcher": "^1.2.0",
    "concurrently": "^9.0.1",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.8.9",
    "husky": "^8.0.3",
    "jsdom": "^26.1.0",
    "lighthouse": "^11.1.0",
    "lint-staged": "^15.5.2",
    "msw": "^2.11.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "puppeteer": "^24.18.0",
    "rimraf": "^5.0.0",
    "rollup-plugin-visualizer": "^5.9.2",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.18",
    "terser": "^5.44.0",
    "tsup": "^7.2.0",
    "tsx": "^4.20.5",
    "turbo": "^1.13.4",
    "typescript": "^5.9.2",
    "vite-bundle-analyzer": "^1.2.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6",
    "web-vitals": "3.4.0"
  },
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "@eslint/eslintrc>ajv": "^6.12.6",
      "@isaacs/brace-expansion": ">=5.0.1",
      "basic-ftp": ">=5.2.0",
      "brace-expansion": ">=1.1.13",
      "cookie": ">=0.7.0",
      "defu": ">=6.1.5",
      "esbuild": ">=0.28.1",
      "eslint>ajv": "^6.12.6",
      "eslint>minimatch": "^3.1.4",
      "express>path-to-regexp": "0.1.13",
      "fast-uri": ">=3.1.1",
      "flatted": ">=3.4.0",
      "glob": "10.5.0",
      "handlebars": ">=4.7.9",
      "ip-address": ">=10.1.1",
      "js-yaml": ">=3.14.2",
      "lodash": ">=4.17.23",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@<3.1.4": "3.1.4",
      "path-to-regexp": "0.1.13",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.10",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "shell-quote": "1.8.4",
      "tar": ">=7.5.7",
      "tar-fs": ">=3.1.1",
      "test-exclude>glob": ">=10.5.0",
      "turbo": ">=2.9.14",
      "typescript": "$typescript",
      "uuid": ">=11.1.1",
      "vite": "6.4.2",
      "ws": ">=8.20.1",
      "yaml": ">=2.8.3"
    }
  }
}
