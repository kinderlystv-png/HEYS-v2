{
    // === Agent Mode (VS Code 1.108+) ===
    "chat.useAgentSkills": true,
    "chat.agentCustomizationSkill.enabled": true,
    "chat.promptFiles": true,
    "chat.subagents.allowInvocationsFromSubagents": true,
    "chat.viewSessions.orientation": "stacked",
    // === Copilot Settings ===
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "github.copilot.chat.reviewSelection.enabled": true,
    "github.copilot.chat.temporalContext.enabled": true,
    "github.copilot.chat.scopeSelection.enabled": true,
    "github.copilot.chat.localeOverride": "ru",
    "github.copilot.chat.customInstructions": [
        "Сначала опирайся на .github/copilot-instructions.md, AGENTS.md и релевантные .instructions.md / .github/skills/*; дополнительные docs читай только по задаче."
    ],
    "github.copilot.chat.editor.enableAutoApply": true,
    "github.copilot.chat.autoApproval.enabled": true,
    "github.copilot.chat.executeCommand.confirmation": "off",
    "github.copilot.chat.terminalShellIntegration": true,
    "chat.editing.confirmEditRequestRemoval": false,
    "github.copilot.chat.codeGeneration.autoInsertEdit": true,
    "github.copilot.chat.commandApproval.enable": false,
    "github.copilot.chat.terminalCommandExecution.confirmAll": false,
    "github.copilot.chat.terminalCommandExecution.confirmDestructive": false,
    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "text": "Формат: type: краткое описание на английском. Types: feat, fix, refactor, docs, chore"
        }
    ],
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#ab307e",
        "activityBar.background": "#ab307e",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#25320e",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#ab307e",
        "statusBar.background": "#832561",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#ab307e",
        "statusBarItem.remoteBackground": "#832561",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#832561",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#83256199",
        "titleBar.inactiveForeground": "#e7e7e799",
        "cSpell.language": "en,ru"
    },
    "peacock.color": "#832561",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit"
    },
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    // ===========================================
    // 🗄️ Yandex Cloud PostgreSQL
    // Переменные в .env (корень проекта). Загрузка:
    //   Windows PowerShell: Get-Content .env | ForEach { if ($_ -match '^([^#].+?)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
    //   Bash/WSL: set -a; source .env; set +a
    //   Или: npx dotenv -- node script.js
    // ===========================================
}